{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile-extension",
      "type": "shell",
      "command": "npm run compile",
      "options": {
        "cwd": "${workspaceFolder}/extension"
      },
      "group": "build",
      "problemMatcher": [
        "$tsc"
      ]
    },
    {
      "label": "package-extension-vsix",
      "type": "shell",
      "command": "npx @vscode/vsce package",
      "options": {
        "cwd": "${workspaceFolder}/extension"
      },
      "problemMatcher": []
    },
    {
      "label": "local-install-extension-vsix",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File \"${workspaceFolder}/scripts/local_extension_install.ps1\"",
      "problemMatcher": []
    }
  ]
}
