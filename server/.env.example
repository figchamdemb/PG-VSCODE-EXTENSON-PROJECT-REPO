# Canonical Postgres target: dedicated `narate-enterprise` database with `narate_enterprise` schema.
# Do not point runtime or scripts back at the retired `egov.narrate` schema.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=narate_enterprise"
STORE_BACKEND="prisma"
NODE_ENV="production"
HOST="0.0.0.0"
PORT="8787"
PUBLIC_BASE_URL="https://pg-ext.addresly.com"
OAUTH_CALLBACK_ORIGINS="https://pg-ext.addresly.com"
OAUTH_CALLBACK_SCHEMES="vscode,cursor,windsurf,vscodium"
OAUTH_EDITOR_CALLBACK_HOSTS="figchamdemb.narrate-vscode-extension,figchamdemb.narrate"

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_REDIRECT_URI="https://pg-ext.addresly.com/auth/github/callback"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://pg-ext.addresly.com/auth/google/callback"

# Keep real Stripe test/live keys in server/.env or your deployment secret manager.
# .env.example must stay placeholder-only.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""
# Current checkout uses Stripe payment mode (one-time prices representing one year of access).
# Create all 9 paid annual price IDs for pro/team/enterprise x narrate/memorybank/bundle.
# Public website pricing text is editable from the admin board; if you want an env seed, set PRICING_CATALOG to JSON.
STRIPE_PRICE_MAP='{"pro:narrate":"price_xxx","pro:memorybank":"price_xxx","pro:bundle":"price_xxx","team:narrate":"price_xxx","team:memorybank":"price_xxx","team:bundle":"price_xxx","enterprise:narrate":"price_xxx","enterprise:memorybank":"price_xxx","enterprise:bundle":"price_xxx"}'
PRICING_CATALOG=""
# Optional: enables encrypted-at-rest Stripe secret persistence for admin-board updates.
# Without this key, Stripe secrets stay env/vault-managed only and are not written to disk.
STRIPE_RUNTIME_VAULT_KEY=""
STRIPE_RUNTIME_CONFIG_PATH=".narrate/stripe-runtime.local.json"
CHECKOUT_SUCCESS_URL="https://pg-ext.addresly.com/checkout/success"
CHECKOUT_CANCEL_URL="https://pg-ext.addresly.com/checkout/cancel"

ADMIN_KEY="replace-me"
ADMIN_ROUTE_PREFIX="/pg-global-admin"
ADMIN_AUTH_MODE="db"
ADMIN_RBAC_BOOTSTRAP="true"
ADMIN_BOOTSTRAP_SUPER_ADMIN_EMAILS="founder@example.com"
SUPER_ADMIN_SOURCE="db"
SUPER_ADMIN_EMAILS="founder@example.com,ops@example.com"
CLOUDFLARE_ACCESS_ENABLED="false"
CLOUDFLARE_ACCESS_TEAM_DOMAIN=""
CLOUDFLARE_ACCESS_AUD=""
CLOUDFLARE_ACCESS_JWKS_TTL_SECONDS="600"

# Local auth-path testing can opt in via server/.env with:
# ENABLE_EMAIL_OTP="true"            # enables the normal code-entry flow in /app and extension sign-in
# EXPOSE_DEV_OTP_CODE="true"         # optional local-only shortcut that exposes dev_code for fast verification
# Keep shared/example defaults disabled.
ENABLE_EMAIL_OTP="false"
EXPOSE_DEV_OTP_CODE="false"
SESSION_COOKIE_NAME="pg_session"
SESSION_COOKIE_SECURE="true"
SESSION_COOKIE_SAMESITE="strict"

AUTH_START_RATE_LIMIT_MAX="20"
AUTH_START_RATE_LIMIT_WINDOW="1 hour"
AUTH_VERIFY_RATE_LIMIT_MAX="5"
AUTH_VERIFY_RATE_LIMIT_WINDOW="5 hours"

GOVERNANCE_ALLOW_PRO="false"
GOVERNANCE_DEFAULT_RETENTION_DAYS="7"
GOVERNANCE_DEFAULT_MAX_DEBATE_CHARS="4000"
GOVERNANCE_SLACK_ADDON_SEAT_PRICE_CENTS="2500"
SLACK_COMMANDS_ENABLED="false"
SLACK_SIGNING_SECRET=""
SLACK_BOT_TOKEN=""
SLACK_WEBHOOK_URL=""
SLACK_ALLOWED_TEAM_IDS=""
SLACK_ALLOWED_EMAILS=""
SLACK_REQUEST_MAX_AGE_SECONDS="300"
