    "@prisma/client": "^6.6.0",
    "dotenv": "^17.3.1",
    "fastify": "^4.28.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^20.16.5",
